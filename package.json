{
  "name": "20260503_ticket_tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run migrate && next dev",
    "build": "next build --webpack && npx @opennextjs/cloudflare build",
    "build:next": "next build --webpack",
    "deploy": "npm run build && npx wrangler deploy",
    "cf:preview": "npm run build:cf && npx wrangler dev",
    "start": "next start",
    "lint": "eslint",
    "migrate": "npx tsx src/db/migrate.ts",
    "migrate:d1": "npx wrangler d1 execute itsm-db --file=./migrations/0001_init.sql && npx wrangler d1 execute itsm-db --file=./migrations/0002_add_users.sql",
    "migrate:d1:remote": "npx wrangler d1 execute itsm-db --file=./migrations/0002_add_users.sql --remote",
    "seed:user": "npx tsx src/db/seed-user.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@libsql/client": "^0.17.3",
    "@opennextjs/cloudflare": "^1.19.5",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.87.0"
  }
}
